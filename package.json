{
  "name": "laundry-box",
  "version": "1.0.1",
  "description": "",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/horizone-dev/Laundry-Box.git"
  },
  "scripts": {
    "start": "electron .",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"wait-on tcp:5173 && npm start\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:frontend": "cd frontend && npm run build",
    "package": "npm run build:frontend && electron-builder --dir",
    "dist": "npm run build:frontend && electron-builder"
  },
  "keywords": [],
  "author": "Horizon Innovations",
  "license": "ISC",
  "build": {
    "appId": "com.laundry.app",
    "productName": "Laundry Box",
    "publish": [
      {
        "provider": "github",
        "owner": "horizone-dev",
        "repo": "Laundry-Box"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "package.json",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/node_modules/",
        "to": "backend/node_modules/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3"
  }
}